@startuml autobill-service-class-diagram

!theme plain
skinparam classAttributeIconSize 0
skinparam linetype polyline
skinparam linetype ortho

title autobill-service - Class Diagram

' ============================================
' ENUMS
' ============================================
enum AccountStatus {
    ACTIVE
    DEACTIVATED
}

enum FriendStatus {
    PENDING
    ACCEPTED
    REJECTED
}

enum GroupRole {
    OWNER
    ADMIN
    MEMBER
}

enum SplitType {
    GROUP
    DIRECT
}

enum SplitDivisionType {
    EQUAL
    CUSTOM
}

enum Currency {
    INR
    USD
    EUR
}

' ============================================
' BASE MODEL
' ============================================
class BaseModel {
    -Id: UUID
    -CreatedAt: time.Time
    -UpdatedAt: time.Time
    -DeletedAt: gorm.DeletedAt
}

' ============================================
' DOMAIN ENTITIES
' ============================================
class User {
    -Email: string
    -Name: string
    -Status: AccountStatus
}

class Credential {
    -UserID: UUID
    -PasswordHash: string
}

class RefreshToken {
    -UserID: UUID
    -Token: string
    -ExpiresAt: time.Time
    -Revoked: bool
}

class FriendRequest {
    -SenderId: UUID
    -ReceiverId: UUID
    -Status: FriendStatus
    -IdempotencyKey: *string
}

class Friendship {
    -UserID: UUID
    -FriendID: UUID
}

class Group {
    -Name: string
    -OwnerID: UUID
    -SimplifyDebts: bool
}

class GroupMembership {
    -UserID: UUID
    -GroupID: UUID
    -Role: GroupRole
}

class Split {
    -Type: SplitType
    -DivisionType: SplitDivisionType
    -TotalAmount: int64
    -Currency: Currency
    -Description: string
    -SimplifyDebts: *bool
    -IdempotencyKey: *string
    -GroupID: *UUID
    -CreatedByID: UUID
}

class SplitParticipant {
    -SplitID: UUID
    -UserID: UUID
    -SettledAmount: int64
    -ShareAmount: int64
    -Currency: Currency
    -IsSettled: bool
}

class Settlement {
    -SplitID: UUID
    -PayerID: UUID
    -PayeeID: UUID
    -Amount: int64
    -Currency: Currency
    -Confirmed: bool
    -Date: time.Time
    -IdempotencyKey: *string
}

class UserBalance {
    -UserID: UUID
    -OtherUserID: UUID
    -NetAmount: int64
    -Currency: Currency
}

class GroupBalance {
    -UserID: UUID
    -GroupID: UUID
    -NetAmount: int64
    -Currency: Currency
}

' ============================================
' RELATIONSHIPS
' ============================================

' Base model embedding
BaseModel <|-- User
BaseModel <|-- Credential
BaseModel <|-- RefreshToken
BaseModel <|-- FriendRequest
BaseModel <|-- Friendship
BaseModel <|-- Group
BaseModel <|-- GroupMembership
BaseModel <|-- Split
BaseModel <|-- SplitParticipant
BaseModel <|-- Settlement
BaseModel <|-- UserBalance
BaseModel <|-- GroupBalance

' User relationships
User "1" -- "1" Credential : has >
User "1" -- "*" RefreshToken : has >
User "1" -- "*" FriendRequest : sends >
User "1" -- "*" FriendRequest : receives >
User "1" -- "*" Friendship : has >
User "1" -- "*" Friendship : friend of >
User "1" -- "*" GroupMembership : has >
User "1" -- "*" Group : owns >
User "1" -- "*" SplitParticipant : participates >
User "1" -- "*" Split : creates >
User "1" -- "*" Settlement : pays >
User "1" -- "*" Settlement : receives >
User "1" -- "*" UserBalance : owns balance >
User "1" -- "*" UserBalance : counterparty >
User "1" -- "*" GroupBalance : has >

' Group relationships
Group "1" -- "*" GroupMembership : contains >
Group "0..1" -- "0..*" Split : has >
Group "1" -- "*" GroupBalance : tracks >

' Split relationships
Split "1" -- "*" SplitParticipant : includes >
Split "1" -- "*" Settlement : settles >

' Enum usage
User ..> AccountStatus : uses
FriendRequest ..> FriendStatus : uses
GroupMembership ..> GroupRole : uses
Split ..> SplitType : uses
Split ..> SplitDivisionType : uses
Split ..> Currency : uses
SplitParticipant ..> Currency : uses
Settlement ..> Currency : uses
UserBalance ..> Currency : uses
GroupBalance ..> Currency : uses

@enduml
