@startuml autobill-service-class-diagram

!theme plain
skinparam classAttributeIconSize 0
skinparam linetype polyline
skinparam linetype ortho

title autobill-service - Class Diagram

' ============================================
' ENUMS
' ============================================
enum AccountStatus {
    ACTIVE
    DEACTIVATED
}

enum FriendStatus {
    PENDING
    ACCEPTED
    REJECTED
}

enum GroupRole {
    OWNER
    ADMIN
    MEMBER
}

enum SplitType {
    GROUP
    DIRECT
}

enum SplitDivisionType {
    EQUAL
    CUSTOM
}

enum Currency {
    INR
    USD
    EUR
}

' ============================================
' DOMAIN ENTITIES
' ============================================
class User {
    -Id: UUID
    -Email: string
    -Name: string
    -Status: AccountStatus
    -CreatedAt: time.Time
    -UpdatedAt: time.Time
}

class Credential {
    -Id: UUID
    -UserID: UUID
    -PasswordHash: string
    -CreatedAt: time.Time
    -UpdatedAt: time.Time
}

class FriendRequest {
    -Id: UUID
    -SenderId: UUID
    -ReceiverId: UUID
    -Status: FriendStatus
    -CreatedAt: time.Time
    -UpdatedAt: time.Time
}

class Friendship {
    -Id: UUID
    -UserID: UUID
    -FriendID: UUID
    -CreatedAt: time.Time
}

class Group {
    -Id: UUID
    -Name: string
    -SimplifyDebts: bool
    -CreatedAt: time.Time
    -UpdatedAt: time.Time
}

class GroupMembership {
    -Id: UUID
    -GroupID: UUID
    -UserID: UUID
    -Role: GroupRole
    -CreatedAt: time.Time
}

class Split {
    -Id: UUID
    -Type: SplitType
    -DivisionType: SplitDivisionType
    -TotalAmount: int64
    -Currency: Currency
    -Description: string
    -IsFinalized: bool
    -SimplifyDebts: *bool
    -GroupID: *UUID
    -CreatedByID: UUID
    -CreatedAt: time.Time
    -UpdatedAt: time.Time
}

class SplitParticipant {
    -Id: UUID
    -SplitID: UUID
    -UserID: UUID
    -ShareAmount: int64
    -Currency: Currency
    -IsSettled: bool
    -CreatedAt: time.Time
    -UpdatedAt: time.Time
}

class Settlement {
    -Id: UUID
    -SplitID: UUID
    -PayerID: UUID
    -PayeeID: UUID
    -Amount: int64
    -Currency: Currency
    -Date: time.Time
    -CreatedAt: time.Time
}

class ReversalSplit {
    -Id: UUID
    -OriginalSplitID: UUID
    -ReversalSplitID: UUID
    -Reason: string
    -CreatedAt: time.Time
}

class UserBalance {
    -Id: UUID
    -UserID: UUID
    -OtherUserID: UUID
    -NetAmount: int64
    -Currency: Currency
    -CreatedAt: time.Time
    -UpdatedAt: time.Time
}

class GroupBalance {
    -Id: UUID
    -UserID: UUID
    -GroupID: UUID
    -NetAmount: int64
    -Currency: Currency
    -CreatedAt: time.Time
    -UpdatedAt: time.Time
}

class AuditLog {
    -Id: UUID
    -UserID: UUID
    -Action: string
    -Timestamp: time.Time
    -CreatedAt: time.Time
}

' ============================================
' RELATIONSHIPS
' ============================================

' User relationships
User "1" -- "1" Credential : has >
User "1" -- "*" FriendRequest : sends >
User "1" -- "*" FriendRequest : receives >
User "1" -- "*" Friendship : has >
User "1" -- "*" GroupMembership : has >
User "1" -- "*" SplitParticipant : participates >
User "1" -- "*" Split : creates >
User "1" -- "*" Settlement : pays >
User "1" -- "*" Settlement : receives >
User "1" -- "*" UserBalance : has >
User "1" -- "*" GroupBalance : has >
User "1" -- "*" AuditLog : generates >

' Friendship (self-referential through User)
Friendship "*" -- "1" User : friend >

' Group relationships
Group "1" -- "*" GroupMembership : contains >
Group "1" -- "*" Split : has >
Group "1" -- "*" GroupBalance : tracks >

' Split relationships
Split "1" -- "*" SplitParticipant : includes >
Split "1" -- "*" Settlement : settles >
Split "1" -- "0..1" ReversalSplit : reversed by >
Split "1" -- "0..1" ReversalSplit : reverses >

' Balance relationships
UserBalance "*" -- "1" User : with other >

' Enum usage
User ..> AccountStatus : uses
FriendRequest ..> FriendStatus : uses
GroupMembership ..> GroupRole : uses
Split ..> SplitType : uses
Split ..> SplitDivisionType : uses
Split ..> Currency : uses
SplitParticipant ..> Currency : uses
Settlement ..> Currency : uses
UserBalance ..> Currency : uses
GroupBalance ..> Currency : uses

@enduml
